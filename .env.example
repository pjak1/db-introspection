# Secrets referenced from DB_conns/**/db_conn.txt via ${VAR}.
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Real environment variables take precedence over `.env`.
# Recommended naming convention: <PROJECT>_<ENVIRONMENT>_<SCHEMA>_<FIELD>
#
# Only DB access secrets belong here. Per-connection behavior (allowed schemas,
# row limits, statement timeout, include_system_schemas) is configured in each
# connection's db_conn.txt, not via environment variables.
#
# Example for connection PROJECT_A/DEV/schema_a:
EXAMPLE_PROJECT_ENV_SCHEMA_USERNAME=example_user
EXAMPLE_PROJECT_ENV_SCHEMA_PASSWORD=change_me

# --- Opt-in write/DDL plugins (default: fully disabled, read-only) ---
# Master switch for the manually installed write plugins in plugins/. Without it,
# plugin files are ignored entirely. WHICH connections may be written to is NOT
# set here: it is a per-connection property — add `writable: true` to that
# connection's DB_conns/<project>/<env>/<schema>/db_conn.txt.
# DB_INTROSPECTION_ENABLE_WRITE_PLUGINS=1
