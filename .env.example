# Secrets referenced from DB_conns/**/db_conn.txt via ${VAR}.
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Real environment variables take precedence over `.env`.
# Recommended naming convention: <PROJECT>_<ENVIRONMENT>_<SCHEMA>_<FIELD>
#
# Example for connection PROJECT_A/DEV/schema_a:
EXAMPLE_PROJECT_ENV_SCHEMA_USERNAME=example_user
EXAMPLE_PROJECT_ENV_SCHEMA_PASSWORD=change_me
