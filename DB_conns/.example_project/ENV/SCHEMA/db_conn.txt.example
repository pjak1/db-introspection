dialect:mssql
host:db-host.example.local
db_name:example_db
port:1433
username:${EXAMPLE_PROJECT_ENV_SCHEMA_USERNAME}
password:${EXAMPLE_PROJECT_ENV_SCHEMA_PASSWORD}
driver:ODBC Driver 18 for SQL Server

# Secrets can be sourced two ways (mix freely across connections):
#   ${VAR}             plaintext, from the environment / .env (as above)
#   credential://NAME  encrypted at rest in the OS keychain (recommended)
# Store keychain secrets with `python -m src.secrets set NAME`. Example:
# password:credential://EXAMPLE_PROJECT_ENV_SCHEMA_PASSWORD

# Allowed schemas for this connection (comma-separated). Also the whitelist
# every tool call is validated against. Defaults to the dialect's default schema.
# schema:schema_a,schema_b

# Optional per-connection behavior (shown with their defaults). These are NOT
# read from the environment — configure them here, per connection.
# default_sample_limit:10
# max_sample_limit:100
# max_select_limit:200
# statement_timeout_ms:5000
# include_system_schemas:false

# Opt this connection in to writes (only effective with a write plugin installed
# and DB_INTROSPECTION_ENABLE_WRITE_PLUGINS enabled). Core-owned, default false.
# writable:true

# Plugin-specific per-connection settings use `plugin.<name>.<key>` keys. The core
# ignores them; the plugin reads them via plugin_config(connection, "<name>").
# plugin.write.mode:dry_run
